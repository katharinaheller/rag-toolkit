# ─────────────────────────────────────────────────────────────────────────
# RAG Toolkit — local environment (TEMPLATE)
#
# Copy this file to `.env` and fill in your real values:
#     cp .env.example .env        (Linux/macOS)
#     Copy-Item .env.example .env (Windows PowerShell)
#
# `.env` is git-ignored and is read automatically by `docker compose`.
# Values here are interpolated into docker-compose.yml / docker-compose.gpu.yml
# at runtime and forwarded down to the notebook + benchmark-runner containers.
# Nothing is baked into any image; the token stays runtime-only and local.
# ─────────────────────────────────────────────────────────────────────────

# HuggingFace access token (read scope is enough for gated model downloads).
# Create one at: https://huggingface.co/settings/tokens
# Required to download gated repos such as google/embeddinggemma-300m.
HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# JupyterHub admin username (must match your signup login).
JUPYTERHUB_ADMIN=admin
